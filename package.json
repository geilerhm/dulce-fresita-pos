{
  "name": "dulce-fresita",
  "version": "1.2.6",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "predev": "npm run rebuild:web --silent",
    "dev": "next dev -p 3847",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 NEXT_TURBOPACK=0 next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "serve": "cross-env PORT=3847 node .next/standalone/server.js",
    "tunnel": "npx cloudflared tunnel --url http://localhost:3847",
    "rebuild:web": "npm rebuild better-sqlite3 usb",
    "rebuild:electron": "npx electron-builder install-app-deps",
    "preelectron:dev": "npm run rebuild:electron --silent",
    "electron:dev": "npm run build && electron .",
    "preelectron:build": "npm run rebuild:electron --silent",
    "electron:build": "bash scripts/build-electron.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.103.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "node-thermal-printer": "^4.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "usb": "^2.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
